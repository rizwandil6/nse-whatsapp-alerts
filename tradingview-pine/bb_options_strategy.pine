// This source code is subject to the terms of the Mozilla Public License 2.0
//@version=6
indicator("BB Options Strategy — Swing & Intraday Bollinger Band Setups", shorttitle = "BB Options Strategy", overlay = true, max_labels_count = 500, max_lines_count = 200)

// =====================================================================
// Implements the Bollinger Band strategy described in the source notes:
// swing entries on pullback-to-20SMA (Daily), intraday "bottle neck"
// squeeze breakouts (15m/5m), and gap/VWAP reversal fades. Built for
// stock options/futures discretionary use — this plots labels on the
// underlying's chart, it does not price or trade the option itself.
//
// PLUS a fourth setup NOT in the source — Trend Continuation. Found
// while validating this indicator against a real SUZLON chart
// (2026-07-20, 09:35–10:35): a strong ~2.7% continuation rally that
// broke above the upper band, above the 20 SMA, and above VWAP fired
// no signal at all, because the Breakout setup requires a squeeze
// (narrow bands) in the preceding 5 bars, and the bands were already
// wide from the prior day's close — there was no squeeze to resolve.
// That's correct behavior for a strict "bottle neck" breakout, but it
// means plain trend continuations without a preceding squeeze are
// permanently out of scope for that setup. Trend Continuation below
// fills that gap. Went through two live-validated iterations against
// that same SUZLON move: v1 required a crossover of the band plus
// above-average volume; v2 (current) simplified further to just price
// already above the 20 SMA and VWAP (below both, for a short) and
// touching the outer band — no crossover, no volume filter. v2 caught
// the move a bar earlier (09:45 vs. 09:50) and, exiting purely on
// band-hugging loss instead of also checking extreme-candle/15m-trail,
// rode it further (to 10:20 vs. an earlier exit) — +1.43% captured in
// one continuous trade. It's mutually exclusive with Breakout — if a
// squeeze DID precede the break, Breakout claims it and Continuation
// stays silent, so a single move never double-fires two entry labels.
//
// The source doc left several things undefined. Rather than silently
// guessing, each one is implemented as an explicit, adjustable input
// and called out here so you know it's an interpretation, not a
// disclosed rule:
//   - "Bottle neck" width  -> Bollinger Band width's percentile rank
//     over a lookback window (ta.percentrank). Default: bottom 20% of
//     the last 100 bars' width counts as a squeeze.
//   - "Decreasing volume"  -> current volume below its own 20-bar
//     average, scaled by an adjustable factor (default 0.8x).
//   - "Leaves the band" (band-hugging exit) -> close moves further than
//     an ATR-scaled buffer away from the outer band for N consecutive
//     bars (defaults: 0.15×ATR buffer, 1 bar confirm).
//   - "Exceptionally large candle" -> current bar's range exceeds an
//     ATR multiple (default 2.5×ATR).
// Every one of these is an input, not a hardcoded guess — tune them to
// match what you actually see happen on the instruments you trade.
//
// Labels use plain trading terminology, unambiguous between opening and
// closing a position: BUY = open long, SELL = close long, SHORT = open
// short, COVER = close short. (An earlier version used just BUY/SELL
// for everything, which made a SELL genuinely impossible to tell apart
// from "closing a long" vs "opening a short" by reading the chart alone
// — fixed after that ambiguity caused real confusion reading a live
// chart.) The underlying setup (swing/breakout/reversal) and exit
// reason (target / SL / band loss / extreme candle / trailing stop)
// are still computed and drive when the label fires, just not printed
// in the label text.
//
// Untested — no Pine Script compiler available in this environment.
// Written against known-correct Pine v6 patterns and reviewed for logic
// bugs, but not compiled/run in TradingView. If it throws a compile
// error on paste, report the exact error back for a fix.
// =====================================================================

// ---------------------------------------------------------------------
// INPUTS
// ---------------------------------------------------------------------
grpCore = "Core Indicators"
bbLen    = input.int(20, "Bollinger Band Length", minval = 2, group = grpCore)
bbMult   = input.float(2.0, "Bollinger Band StdDev Mult", minval = 0.1, step = 0.1, group = grpCore)
ema9Len  = input.int(9, "EMA Length (early-entry helper)", minval = 1, group = grpCore)
atrLen   = input.int(14, "ATR Length", minval = 1, group = grpCore)
showBands = input.bool(true, "Plot Bollinger Bands", group = grpCore)
showVwapEma = input.bool(true, "Plot VWAP / 9 EMA", group = grpCore)

grpSwing = "Swing Setup (intended for Daily chart)"
enableSwing      = input.bool(true, "Enable Swing Signals", group = grpSwing,
     tooltip = "Source rule: uptrend on Daily, enter on pullback to the 20 SMA with a green candle. Pine indicators can't force your chart's timeframe — this works on any TF you apply it to, but the setup is only meaningful on Daily as described.")
swingTrendLen    = input.int(5, "Uptrend Confirm Bars (SMA rising over N bars)", minval = 1, group = grpSwing)
swingPullbackATR = input.float(0.5, "Pullback Proximity to 20 SMA (× ATR)", minval = 0.05, step = 0.05, group = grpSwing,
     tooltip = "How close price must get to the 20 SMA to count as a 'touch'. Not specified numerically by the source — this is an operationalized proxy.")

grpBreak = "Intraday Breakout / Bottle Neck (15m or 5m)"
enableBreakout       = input.bool(true, "Enable Breakout Signals", group = grpBreak)
squeezeLookback      = input.int(100, "Squeeze Percentile Lookback (bars)", minval = 20, group = grpBreak)
squeezeThreshold     = input.float(20, "Squeeze Threshold (percentile, lower = tighter)", minval = 1, maxval = 100, group = grpBreak,
     tooltip = "Band width must rank in the bottom X% of its own recent history to count as a 'bottle neck'. Source gives no fixed width — this is an operationalized proxy.")
squeezeVolFactor     = input.float(0.8, "Squeeze Volume Factor (× session avg volume)", minval = 0.1, step = 0.1, group = grpBreak,
     tooltip = "Volume must be below this fraction of today's session average during the squeeze. Compared against a session-scoped average (resets daily, like VWAP), not a plain rolling SMA — a rolling window blends in the prior day's volume regime, which broke this comparison badly after a high-volume day. Source says 'decreasing volume' with no threshold — operationalized proxy.")
squeezeConfirmWindow = input.int(5, "Breakout Must Occur Within N Bars of Squeeze", minval = 1, group = grpBreak)

grpReversal = "Reversal Setup (Gap Up/Down Fade)"
enableReversal    = input.bool(true, "Enable Reversal Signals", group = grpReversal)
gapATRMult        = input.float(0.5, "Min Distance Beyond Band to Count as 'Gap' (× session ATR)", minval = 0.05, step = 0.05, group = grpReversal,
     tooltip = "Compared against a session-scoped ATR (resets daily), not the shared 14-bar atrVal used elsewhere in this script — the shared one blends in the prior day's range for roughly the first 70 minutes of a new session, which can distort 'is this an unusual gap' right when it matters most. Extreme-candle exit and hug buffer still use the shared multi-day ATR, since smoothing across days is more defensible for stop sizing than for a same-day gap judgment.")
reversalLookback  = input.int(15, "Max Bars to Wait for VWAP Reclaim After Gap", minval = 1, group = grpReversal)

grpContinuation = "Trend Continuation (no squeeze required — NOT in source)"
enableContinuation    = input.bool(true, "Enable Trend Continuation Signals", group = grpContinuation,
     tooltip = "Added after live validation showed the squeeze-gated Breakout setup misses plain trend continuations that never pause into a low-volatility squeeze. Simplified after a second validation round: price already above the 20 SMA and VWAP (below both, for a short), touching the outer band — no crossover, no volume filter, no squeeze. Exits purely via band-hugging loss (no extreme-candle or 15m-trail exit) — tested against the real move this setup was built for and rode more of it than the crossover+volume version did. Mutually exclusive with Breakout — a squeeze-preceded break is always claimed by Breakout, never both.")

grpExit = "Exit Rules"
enableBandHugExit    = input.bool(true, "Enable Band-Hugging Exit (Breakout trades)", group = grpExit)
hugBufferATR         = input.float(0.15, "Band-Hug Buffer (× ATR)", minval = 0.01, step = 0.01, group = grpExit,
     tooltip = "How far price must move away from the outer band, in ATR terms, before it counts as having 'left' the band. Source describes this visually with no number — operationalized proxy.")
hugConfirmBars       = input.int(1, "Bars Beyond Buffer to Confirm Exit", minval = 1, group = grpExit)
enableExtremeExit    = input.bool(true, "Enable Extreme-Candle Exit", group = grpExit)
extremeMoveATRMult   = input.float(2.5, "Extreme Candle Range (× ATR)", minval = 0.5, step = 0.1, group = grpExit)
enableTrail15m       = input.bool(true, "Enable 15m-Candle Trailing Stop (Breakout + Reversal)", group = grpExit,
     tooltip = "Source rule: trail intraday stops using the low (long) / high (short) of each 15-minute candle, regardless of your current chart timeframe.")

grpStyle = "Label Style"
lblSize = input.string(size.small, "Label Size", options = [size.tiny, size.small, size.normal, size.large], group = grpStyle)
showSqueezeBg = input.bool(true, "Highlight Squeeze Background", group = grpStyle)

// ---------------------------------------------------------------------
// CORE CALCULATIONS
// ---------------------------------------------------------------------
sma20   = ta.sma(close, bbLen)
dev     = bbMult * ta.stdev(close, bbLen)
upperBB = sma20 + dev
lowerBB = sma20 - dev
vwapVal = ta.vwap(hlc3)
ema9    = ta.ema(close, ema9Len)
atrVal  = ta.atr(atrLen)

// Session-scoped volume average (resets each day, same as VWAP above) —
// a plain N-bar SMA blends across day boundaries. Found via live
// validation: 2026-07-17 traded 111M shares vs. 2026-07-20's 51M, and
// that carryover inflated the rolling 20-bar average so badly near the
// 20th's open that the volume-expansion filter below (and the squeeze
// filter) could never fire, even on the day's own genuine breakout
// volume. Unstable on the first few bars of a session (few samples),
// same inherent tradeoff VWAP already has — accepted for the same reason.
newSession = ta.change(time("D")) != 0
var float sessionVolSum   = 0.0
var int   sessionVolCount = 0
if newSession
    sessionVolSum   := 0.0
    sessionVolCount := 0
sessionVolSum   += volume
sessionVolCount += 1
sessionAvgVol = sessionVolSum / sessionVolCount

// Session-scoped ATR, same reasoning applied to Reversal's gap-distance
// threshold (gapATRMult * atr): the shared 14-bar atrVal above blends
// in the prior session's range for roughly the first 70 minutes of a
// new day (14 bars × 5m), so a big-range prior day can inflate "how big
// a gap has to be to count" right when the new session opens — the same
// class of cross-day contamination that broke the volume filters.
// Deliberately scoped to Reversal's gap threshold only, not swapped in
// for atrVal everywhere (extreme-candle exit, hug buffer, label
// offsets) — those weren't the ones found broken, and ATR's usual
// multi-day smoothing is more defensible for stop/exit sizing than for
// a same-day "is this an unusual gap" judgment.
trueRangeNow = na(close[1]) ? high - low : math.max(high - low, math.abs(high - close[1]), math.abs(low - close[1]))
var float sessionTrSum   = 0.0
var int   sessionTrCount = 0
if newSession
    sessionTrSum   := 0.0
    sessionTrCount := 0
sessionTrSum   += trueRangeNow
sessionTrCount += 1
sessionAtr = sessionTrSum / sessionTrCount

plot(showBands ? sma20 : na, "20 SMA (Middle Band)", color = color.new(color.orange, 0), linewidth = 1)
p1 = plot(showBands ? upperBB : na, "Upper Band", color = color.new(color.gray, 30))
p2 = plot(showBands ? lowerBB : na, "Lower Band", color = color.new(color.gray, 30))
fill(p1, p2, color = color.new(color.gray, 92))
plot(showVwapEma ? vwapVal : na, "VWAP", color = color.new(color.blue, 0), linewidth = 2)
plot(showVwapEma ? ema9 : na, "9 EMA", color = color.new(color.purple, 40))

// ---------------------------------------------------------------------
// BOTTLE NECK (SQUEEZE) DETECTION
// ---------------------------------------------------------------------
bbWidthPct     = (upperBB - lowerBB) / sma20 * 100
widthPctRank   = ta.percentrank(bbWidthPct, squeezeLookback)
squeezeNow     = widthPctRank <= squeezeThreshold and volume < sessionAvgVol * squeezeVolFactor
barsSinceSqueeze = ta.barssince(squeezeNow)
recentSqueeze  = not na(barsSinceSqueeze) and barsSinceSqueeze <= squeezeConfirmWindow

bgcolor(showSqueezeBg and squeezeNow ? color.new(color.yellow, 85) : na, title = "Squeeze Zone")

// ---------------------------------------------------------------------
// 15-MINUTE TRAILING STOP (for intraday breakout / reversal trades)
// ---------------------------------------------------------------------
trail15Low  = request.security(syminfo.tickerid, "15", low[1], lookahead = barmerge.lookahead_off)
trail15High = request.security(syminfo.tickerid, "15", high[1], lookahead = barmerge.lookahead_off)

// ---------------------------------------------------------------------
// STATE — one active position per setup type at a time
// ---------------------------------------------------------------------
var bool  inBreakoutLong     = false
var bool  inBreakoutShort    = false
var bool  inSwingLong        = false
var bool  inReversalLong     = false
var bool  inReversalShort    = false
var bool  inContinuationLong  = false
var bool  inContinuationShort = false

var int   hugAwayCountL  = 0
var int   hugAwayCountS  = 0
var int   hugAwayCountCL = 0
var int   hugAwayCountCS = 0

var float recentExtremeTopPrice = na
var int   recentExtremeTopBar   = na
var float recentExtremeBotPrice = na
var int   recentExtremeBotBar   = na

var float reversalLongSL  = na
var float reversalShortSL = na

// ---------------------------------------------------------------------
// SWING ENTRY — pullback to 20 SMA in an uptrend, green candle (Daily)
// ---------------------------------------------------------------------
swingUptrend   = sma20 > sma20[swingTrendLen]
swingPullback  = math.abs(low - sma20) <= swingPullbackATR * atrVal
swingGreen     = close > open
swingBuyCond   = enableSwing and swingUptrend and swingPullback and swingGreen and not inSwingLong and not inBreakoutLong and not inBreakoutShort

if swingBuyCond
    inSwingLong := true
    label.new(bar_index, low - atrVal * 0.5, "BUY", style = label.style_label_up,
         color = color.new(color.green, 0), textcolor = color.white, size = lblSize)

if inSwingLong and not swingBuyCond
    if high >= upperBB or close < sma20
        label.new(bar_index, high + atrVal * 0.5, "SELL", style = label.style_label_down,
             color = color.new(color.red, 0), textcolor = color.white, size = lblSize)
        inSwingLong := false

// ---------------------------------------------------------------------
// INTRADAY BREAKOUT — squeeze resolves with a directional break
// ---------------------------------------------------------------------
breakoutLongCond  = enableBreakout and recentSqueeze and ta.crossover(close, upperBB) and close > sma20 and close > vwapVal and not inBreakoutLong and not inBreakoutShort and not inSwingLong
breakoutShortCond = enableBreakout and recentSqueeze and ta.crossunder(close, lowerBB) and close < sma20 and close < vwapVal and not inBreakoutLong and not inBreakoutShort and not inSwingLong

if breakoutLongCond
    inBreakoutLong := true
    hugAwayCountL := 0
    label.new(bar_index, low - atrVal * 0.5, "BUY", style = label.style_label_up,
         color = color.new(color.green, 0), textcolor = color.white, size = lblSize)

if breakoutShortCond
    inBreakoutShort := true
    hugAwayCountS := 0
    label.new(bar_index, high + atrVal * 0.5, "SHORT", style = label.style_label_down,
         color = color.new(color.maroon, 0), textcolor = color.white, size = lblSize)

// Breakout LONG exits — closing a long prints SELL
if inBreakoutLong and not breakoutLongCond
    extremeCandle = enableExtremeExit and (high - low) > extremeMoveATRMult * atrVal
    distFromBand  = upperBB - close
    if distFromBand > hugBufferATR * atrVal
        hugAwayCountL += 1
    else
        hugAwayCountL := 0
    hugExit   = enableBandHugExit and hugAwayCountL >= hugConfirmBars
    trailExit = enableTrail15m and close < trail15Low
    if extremeCandle or hugExit or trailExit
        label.new(bar_index, high + atrVal * 0.5, "SELL", style = label.style_label_down,
             color = color.new(color.red, 0), textcolor = color.white, size = lblSize)
        inBreakoutLong := false

// Breakout SHORT exits — closing a short prints COVER
if inBreakoutShort and not breakoutShortCond
    extremeCandleS = enableExtremeExit and (high - low) > extremeMoveATRMult * atrVal
    distFromBandS  = close - lowerBB
    if distFromBandS > hugBufferATR * atrVal
        hugAwayCountS += 1
    else
        hugAwayCountS := 0
    hugExitS   = enableBandHugExit and hugAwayCountS >= hugConfirmBars
    trailExitS = enableTrail15m and close > trail15High
    if extremeCandleS or hugExitS or trailExitS
        label.new(bar_index, low - atrVal * 0.5, "COVER", style = label.style_label_up,
             color = color.new(color.teal, 0), textcolor = color.white, size = lblSize)
        inBreakoutShort := false

// ---------------------------------------------------------------------
// TREND CONTINUATION — simplified per live validation: price already
// above the 20 SMA and VWAP (below/below for short), touching the
// outer band, no crossover/volume/squeeze gate required. Exits purely
// on band-hugging loss — no extreme-candle or 15m-trail exit here, by
// design (see input tooltip for why). Not in source.
// ---------------------------------------------------------------------
continuationLongCond  = enableContinuation and not recentSqueeze and high >= upperBB and close > sma20 and close > vwapVal and not inBreakoutLong and not inBreakoutShort and not inContinuationLong and not inContinuationShort and not inSwingLong
continuationShortCond = enableContinuation and not recentSqueeze and low <= lowerBB and close < sma20 and close < vwapVal and not inBreakoutLong and not inBreakoutShort and not inContinuationLong and not inContinuationShort

if continuationLongCond
    inContinuationLong := true
    hugAwayCountCL := 0
    label.new(bar_index, low - atrVal * 0.5, "BUY", style = label.style_label_up,
         color = color.new(color.green, 0), textcolor = color.white, size = lblSize)

if continuationShortCond
    inContinuationShort := true
    hugAwayCountCS := 0
    label.new(bar_index, high + atrVal * 0.5, "SHORT", style = label.style_label_down,
         color = color.new(color.maroon, 0), textcolor = color.white, size = lblSize)

// Continuation LONG exit — band-hugging loss only; closing a long prints SELL
if inContinuationLong and not continuationLongCond
    distFromBandCL = upperBB - close
    if distFromBandCL > hugBufferATR * atrVal
        hugAwayCountCL += 1
    else
        hugAwayCountCL := 0
    if enableBandHugExit and hugAwayCountCL >= hugConfirmBars
        label.new(bar_index, high + atrVal * 0.5, "SELL", style = label.style_label_down,
             color = color.new(color.red, 0), textcolor = color.white, size = lblSize)
        inContinuationLong := false

// Continuation SHORT exit — band-hugging loss only; closing a short prints COVER
if inContinuationShort and not continuationShortCond
    distFromBandCS = close - lowerBB
    if distFromBandCS > hugBufferATR * atrVal
        hugAwayCountCS += 1
    else
        hugAwayCountCS := 0
    if enableBandHugExit and hugAwayCountCS >= hugConfirmBars
        label.new(bar_index, low - atrVal * 0.5, "COVER", style = label.style_label_up,
             color = color.new(color.teal, 0), textcolor = color.white, size = lblSize)
        inContinuationShort := false

// ---------------------------------------------------------------------
// REVERSAL — gap outside the bands, fade back through VWAP
// ---------------------------------------------------------------------
extremeHigh = high > upperBB + gapATRMult * sessionAtr
extremeLow  = low < lowerBB - gapATRMult * sessionAtr

if extremeHigh
    recentExtremeTopPrice := high
    recentExtremeTopBar   := bar_index
if extremeLow
    recentExtremeBotPrice := low
    recentExtremeBotBar   := bar_index

topStillValid = not na(recentExtremeTopBar) and (bar_index - recentExtremeTopBar) <= reversalLookback
botStillValid = not na(recentExtremeBotBar) and (bar_index - recentExtremeBotBar) <= reversalLookback

reversalShortCond = enableReversal and topStillValid and ta.crossunder(close, vwapVal) and not inReversalShort and not inReversalLong
reversalLongCond  = enableReversal and botStillValid and ta.crossover(close, vwapVal) and not inReversalShort and not inReversalLong

if reversalShortCond
    inReversalShort := true
    reversalShortSL := recentExtremeTopPrice
    recentExtremeTopBar := na
    label.new(bar_index, high + atrVal * 0.5, "SHORT", style = label.style_label_down,
         color = color.new(color.maroon, 0), textcolor = color.white, size = lblSize)

if reversalLongCond
    inReversalLong := true
    reversalLongSL := recentExtremeBotPrice
    recentExtremeBotBar := na
    label.new(bar_index, low - atrVal * 0.5, "BUY", style = label.style_label_up,
         color = color.new(color.green, 0), textcolor = color.white, size = lblSize)

// Reversal LONG exit — SL at the recent gap-down low, or 15m trail — closing a long prints SELL
if inReversalLong and not reversalLongCond
    slHitL = close < reversalLongSL
    trailExitRL = enableTrail15m and close < trail15Low
    if slHitL or trailExitRL
        label.new(bar_index, high + atrVal * 0.5, "SELL", style = label.style_label_down,
             color = color.new(color.red, 0), textcolor = color.white, size = lblSize)
        inReversalLong := false

// Reversal SHORT exit — SL at the recent gap-up high, or 15m trail — closing a short prints COVER
if inReversalShort and not reversalShortCond
    slHitS = close > reversalShortSL
    trailExitRS = enableTrail15m and close > trail15High
    if slHitS or trailExitRS
        label.new(bar_index, low - atrVal * 0.5, "COVER", style = label.style_label_up,
             color = color.new(color.teal, 0), textcolor = color.white, size = lblSize)
        inReversalShort := false

// ---------------------------------------------------------------------
// STATUS TABLE
// ---------------------------------------------------------------------
var table statusTable = table.new(position.top_right, 2, 7, border_width = 1)
if barstate.islast
    table.cell(statusTable, 0, 0, "Setup", bgcolor = color.new(color.black, 0), text_color = color.white)
    table.cell(statusTable, 1, 0, "State", bgcolor = color.new(color.black, 0), text_color = color.white)
    table.cell(statusTable, 0, 1, "Squeeze")
    table.cell(statusTable, 1, 1, squeezeNow ? "ACTIVE" : "—", text_color = squeezeNow ? color.orange : color.gray)
    table.cell(statusTable, 0, 2, "Swing")
    table.cell(statusTable, 1, 2, inSwingLong ? "LONG" : "flat", text_color = inSwingLong ? color.green : color.gray)
    table.cell(statusTable, 0, 3, "Breakout")
    table.cell(statusTable, 1, 3, inBreakoutLong ? "LONG" : inBreakoutShort ? "SHORT" : "flat",
         text_color = inBreakoutLong ? color.green : inBreakoutShort ? color.red : color.gray)
    table.cell(statusTable, 0, 4, "Continuation")
    table.cell(statusTable, 1, 4, inContinuationLong ? "LONG" : inContinuationShort ? "SHORT" : "flat",
         text_color = inContinuationLong ? color.green : inContinuationShort ? color.red : color.gray)
    table.cell(statusTable, 0, 5, "Reversal")
    table.cell(statusTable, 1, 5, inReversalLong ? "LONG" : inReversalShort ? "SHORT" : "flat",
         text_color = inReversalLong ? color.green : inReversalShort ? color.red : color.gray)
    table.cell(statusTable, 0, 6, "BB Width %ile")
    table.cell(statusTable, 1, 6, str.tostring(math.round(widthPctRank)) + "%")

// ---------------------------------------------------------------------
// ALERTS
// ---------------------------------------------------------------------
alertcondition(swingBuyCond, "Swing Buy", "BB Swing Buy: pullback to 20 SMA in uptrend")
alertcondition(breakoutLongCond, "Breakout Buy", "BB Breakout Buy: squeeze resolved upward")
alertcondition(breakoutShortCond, "Breakout Short", "BB Breakout Short: squeeze resolved downward")
alertcondition(continuationLongCond, "Continuation Buy", "BB Continuation Buy: trend break without a prior squeeze")
alertcondition(continuationShortCond, "Continuation Short", "BB Continuation Short: trend break without a prior squeeze")
alertcondition(reversalLongCond, "Reversal Buy", "BB Reversal Buy: gap-down fade reclaiming VWAP")
alertcondition(reversalShortCond, "Reversal Short", "BB Reversal Short: gap-up fade losing VWAP")
