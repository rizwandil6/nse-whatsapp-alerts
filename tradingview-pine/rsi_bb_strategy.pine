// This source code is subject to the terms of the Mozilla Public License 2.0
//@version=6
indicator("RSI + Bollinger Bands Strategy", shorttitle = "RSI+BB Strategy", overlay = true, max_labels_count = 500)

// =====================================================================
// Implements the source's rule exactly:
//   - Wait for RSI to be overbought (>70) or oversold (<30).
//   - Ensure price is trading OUTSIDE the Bollinger Bands (above the
//     upper band while overbought, below the lower band while oversold).
//   - Wait for price to cross back through the MIDDLE Bollinger Band
//     for entry — BUY on the oversold side, SHORT on the overbought
//     side.
// RSI (leading momentum) flags the extreme; price crossing back through
// the middle band (lagging, confirms the reversal is actually underway)
// is the trigger — that's the whole point of combining the two, per the
// source's own framing.
//
// What the source left completely unspecified, operationalized here:
//   - Exit rule — genuinely not mentioned at all, unlike the BBMA
//     strategy (which explicitly says "close on opposite crossover").
//     Reused that same idea here for consistency, since it's the
//     simplest defensible default: close on a crossing of the middle
//     band in the opposite direction. This is an invented default, not
//     a disclosed rule — flagged so you know to treat it as a starting
//     point, not gospel.
//   - How long to wait, after RSI goes overbought/oversold with price
//     outside the band, for the middle-band cross to actually happen —
//     the source just says "wait," no bound given. Added an adjustable
//     max-bars-to-wait input (same pattern used in this folder's other
//     BB+VWAP reversal setup for the identical kind of gap).
//   - RSI length and Bollinger Band length/multiplier — not stated.
//     Used the universal defaults (RSI 14, BB 20/2.0), same assumption
//     as this folder's other scripts.
//
// RSI isn't plotted as an overlay line — its 0-100 scale is meaningless
// stacked on a price chart, and Pine can't mix an overlay pane with a
// separate oscillator pane in one script. Current RSI value and
// overbought/oversold state are shown in the status table instead.
//
// Untested — no Pine Script compiler available in this environment.
// Written against known-correct Pine v6 patterns, manually reviewed for
// signature/type errors, but not compiled in TradingView. If it throws
// a compile error on paste, report the exact error back for a fix.
// =====================================================================

// ---------------------------------------------------------------------
// INPUTS
// ---------------------------------------------------------------------
grpCore = "Core Indicators"
bbLen   = input.int(20, "Bollinger Band Length", minval = 2, group = grpCore,
     tooltip = "Not specified by the source — using the universal default (20, 2.0 stdev).")
bbMult  = input.float(2.0, "Bollinger Band StdDev Mult", minval = 0.1, step = 0.1, group = grpCore)
rsiLen  = input.int(14, "RSI Length", minval = 1, group = grpCore,
     tooltip = "Not specified by the source — using the universal default (14).")
showBands = input.bool(true, "Plot Bollinger Bands", group = grpCore)

grpRsi = "RSI Extreme"
rsiOverbought = input.float(70, "Overbought Level", minval = 50, maxval = 99, group = grpRsi,
     tooltip = "Source rule: RSI above this counts as overbought.")
rsiOversold   = input.float(30, "Oversold Level", minval = 1, maxval = 50, group = grpRsi,
     tooltip = "Source rule: RSI below this counts as oversold.")
armedLookback = input.int(20, "Max Bars to Wait for Middle-Band Cross After RSI Extreme", minval = 1, group = grpRsi,
     tooltip = "Source says 'wait for the price to cross the middle band' with no time bound. This caps how long the RSI-extreme-plus-outside-band condition stays 'armed' waiting for that cross — not a disclosed rule, an operationalized proxy.")

grpExit = "Exit Rule (NOT specified by source)"
exitOnOppositeCross = input.bool(true, "Exit on Opposite Middle-Band Crossover", group = grpExit,
     tooltip = "The source gives no exit rule for this strategy at all. This closes the position when price crosses the middle band in the opposite direction — the simplest defensible default, reusing the same idea as the sibling BBMA strategy's explicit exit rule. Treat this as a starting point you should replace with your own risk management, not a disclosed rule.")

grpStyle = "Label Style"
lblSize = input.string(size.small, "Label Size", options = [size.tiny, size.small, size.normal, size.large], group = grpStyle)

// ---------------------------------------------------------------------
// CORE CALCULATIONS
// ---------------------------------------------------------------------
bbBasis = ta.sma(close, bbLen)
bbDev   = bbMult * ta.stdev(close, bbLen)
upperBB = bbBasis + bbDev
lowerBB = bbBasis - bbDev
rsiVal  = ta.rsi(close, rsiLen)

plot(showBands ? bbBasis : na, "Middle Bollinger Band", color = color.new(color.orange, 0), linewidth = 1)
p1 = plot(showBands ? upperBB : na, "Upper Band", color = color.new(color.gray, 30))
p2 = plot(showBands ? lowerBB : na, "Lower Band", color = color.new(color.gray, 30))
fill(p1, p2, color = color.new(color.gray, 92))

// ---------------------------------------------------------------------
// ARM / DISARM — RSI extreme + price outside the band
// ---------------------------------------------------------------------
oversoldNow   = rsiVal < rsiOversold and close < lowerBB
overboughtNow = rsiVal > rsiOverbought and close > upperBB

var int armedOversoldBar   = na
var int armedOverboughtBar = na

if oversoldNow
    armedOversoldBar := bar_index
if overboughtNow
    armedOverboughtBar := bar_index

oversoldArmed   = not na(armedOversoldBar) and (bar_index - armedOversoldBar) <= armedLookback
overboughtArmed = not na(armedOverboughtBar) and (bar_index - armedOverboughtBar) <= armedLookback

// ---------------------------------------------------------------------
// ENTRY — price crosses back through the middle band while armed
// ---------------------------------------------------------------------
var bool inLong  = false
var bool inShort = false

longCond  = oversoldArmed and ta.crossover(close, bbBasis) and not inLong and not inShort
shortCond = overboughtArmed and ta.crossunder(close, bbBasis) and not inLong and not inShort

if longCond
    inLong := true
    armedOversoldBar := na
    label.new(bar_index, low - (high - low) * 0.5, "BUY", style = label.style_label_up,
         color = color.new(color.green, 0), textcolor = color.white, size = lblSize)

if shortCond
    inShort := true
    armedOverboughtBar := na
    label.new(bar_index, high + (high - low) * 0.5, "SHORT", style = label.style_label_down,
         color = color.new(color.maroon, 0), textcolor = color.white, size = lblSize)

// ---------------------------------------------------------------------
// EXIT — opposite middle-band crossover (operationalized, not in source)
// ---------------------------------------------------------------------
if exitOnOppositeCross and inLong and ta.crossunder(close, bbBasis)
    label.new(bar_index, high + (high - low) * 0.5, "SELL", style = label.style_label_down,
         color = color.new(color.red, 0), textcolor = color.white, size = lblSize)
    inLong := false

if exitOnOppositeCross and inShort and ta.crossover(close, bbBasis)
    label.new(bar_index, low - (high - low) * 0.5, "COVER", style = label.style_label_up,
         color = color.new(color.teal, 0), textcolor = color.white, size = lblSize)
    inShort := false

// ---------------------------------------------------------------------
// STATUS TABLE
// ---------------------------------------------------------------------
var table statusTable = table.new(position.top_right, 2, 3, border_width = 1)
if barstate.islast
    table.cell(statusTable, 0, 0, "RSI+BB", bgcolor = color.new(color.black, 0), text_color = color.white)
    table.cell(statusTable, 1, 0, "State", bgcolor = color.new(color.black, 0), text_color = color.white)
    table.cell(statusTable, 0, 1, "RSI")
    table.cell(statusTable, 1, 1, str.tostring(math.round(rsiVal)) + (rsiVal > rsiOverbought ? " (OB)" : rsiVal < rsiOversold ? " (OS)" : ""),
         text_color = rsiVal > rsiOverbought ? color.red : rsiVal < rsiOversold ? color.green : color.gray)
    table.cell(statusTable, 0, 2, "Position")
    table.cell(statusTable, 1, 2, inLong ? "LONG" : inShort ? "SHORT" : "flat",
         text_color = inLong ? color.green : inShort ? color.red : color.gray)

// ---------------------------------------------------------------------
// ALERTS
// ---------------------------------------------------------------------
alertcondition(longCond, "RSI+BB Buy", "RSI+BB Strategy: oversold reversal, price crossed back above middle band")
alertcondition(shortCond, "RSI+BB Short", "RSI+BB Strategy: overbought reversal, price crossed back below middle band")
