{
  "name": "NSE WhatsApp Alerts (Java 17 + Maven)",
  "image": "mcr.microsoft.com/devcontainers/java:17",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "installMaven": true
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot",
        "vscjava.vscode-spring-initializr"
      ]
    }
  },
  "forwardPorts": [8080],
  "postCreateCommand": "mvn -q -DskipTests package || true"
}
